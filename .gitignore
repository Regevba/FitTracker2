# Xcode
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.xccheckout

# Build products
build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/

# CocoaPods (not used, but just in case)
Pods/

# Carthage (not used, but just in case)
Carthage/Build/

# macOS
.DS_Store

# VS Code workspace files
*.code-workspace

# Local Codex / workspace artifacts
.claude/
!.claude/
!.claude/skills/
!.claude/skills/**
!.claude/shared/
!.claude/shared/**
!.claude/features/
!.claude/features/**
!.claude/integrity/
!.claude/integrity/**
!.claude/logs/
!.claude/logs/**
.claude/logs/_session-*.events.jsonl
.claude/active-feature
.claude/logs/gate-coverage.jsonl
.claude/shared/preflight-cache.json
.claude/shared/integrity-checkpoint-regression.flag
.claude/worktrees/
!.claude/entrypoints/
!.claude/entrypoints/**
!.claude/settings.json
# Session-specific lock files (regenerated per session, never commit)
.claude/scheduled_tasks.lock
.claude/logs/*.lock
.claude/logs/*.lock.json
.superpowers/
.worktrees/
FitMe-GDPR-Docs/

# Local Xcode package resolution
FitTracker.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
node_modules/

# Python
__pycache__/
*.pyc
*.pyo
dashboard/node_modules/
dashboard/dist/
dashboard/.vercel/

# SSD-local build artifacts (caches, DerivedData, venvs, npm cache; .build/ also covered above)
orchid/.venv/

# Firebase credentials (local only, contains secrets)
GoogleService-Info.plist

# Local Xcode runtime overlays (real staging/debug credentials stay out of git)
Config/Local/*.xcconfig
!Config/Local/*.example.xcconfig
!Config/Local/README.md

# Auth-polish-v2 / Sentry / HADF / Vercel local artifacts (never commit)
.env.local
.sentryclirc
.venv-hadf-phase2/
.vercel/
.claude/shared/hadf/logs/
.claude/shared/hadf/pre-merge-backup-*/
.claude/shared/hadf/incident-*-recovery/
.claude/shared/hadf/*.pre-isolation-archive
.claude/shared/sentry-recovery/

# HADF Phase 2 raw observational data — gitignored per pre-registration
# (the committed summary derives from this; raw stays local to preserve the
# pre-registered "verdict is a pure function of (prereg, summary)" contract).
# NOTE: only the raw .jsonl files are excluded — the summary + preregistration
# JSON files ARE committed to satisfy the case study's T1 traceability claim
# (docs/case-studies/hadf-phase2-cloud-fingerprinting-case-study.md cites
# both files at commit 61964d3 as "the assessable inputs").
.claude/shared/hadf/phase2-fingerprint-raw*.jsonl
# HADF Phase 2-bis wrapper preflight test logs — transient outputs only,
# not deliverables. Real-run heartbeats go to phase2bis-fire-heartbeat.jsonl
# (which IS committed for path stability).
.claude/shared/hadf/phase2bis-deploy-verification/
.cache/
.claude/_session-state/

# Audit bundles — commit per-run artifacts for public reproducibility
# (decided 2026-05-19, spec §12 OQ #1). Each run directory commits
# bundle.md, manifest.json, redaction-log.json, plus the auditor's report.
# Only ad-hoc scratch / cache files under runs/*/ stay gitignored.
docs/audits/runs/*/scratch/
docs/audits/runs/*/.cache/
docs/audits/runs/*/*.tmp
