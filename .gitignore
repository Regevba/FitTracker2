# Xcode
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.xccheckout

# Build products
build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/

# CocoaPods (not used, but just in case)
Pods/

# Carthage (not used, but just in case)
Carthage/Build/

# macOS
.DS_Store

# VS Code workspace files
*.code-workspace

# Local Codex / workspace artifacts
.claude/
!.claude/
!.claude/skills/
!.claude/skills/**
!.claude/shared/
!.claude/shared/**
!.claude/features/
!.claude/features/**
!.claude/integrity/
!.claude/integrity/**
!.claude/logs/
!.claude/logs/**
.claude/logs/_session-*.events.jsonl
.claude/active-feature
.claude/logs/gate-coverage.jsonl
.claude/logs/devssd-uuid-watcher.log
.claude/shared/preflight-cache.json
# Ephemeral lease registry: written at runtime by w9_auto_isolate.touch_own_lease
# (heartbeat on every Bash) + create-isolated-worktree.py. A lease is live-session
# state, not source — tracking it made the file perpetually dirty once the
# per-Bash heartbeat landed (2026-07-24). All readers tolerate its absence
# (membrane-status/another_session_live default to empty; writers self-create).
.claude/shared/agent-leases.json
.claude/shared/integrity-checkpoint-regression.flag
.claude/shared/backup-verify-result.json
.claude/shared/backup-verify-failed.flag
.claude/worktrees/
!.claude/entrypoints/
!.claude/entrypoints/**
!.claude/settings.json
# Session-specific lock files (regenerated per session, never commit)
.claude/scheduled_tasks.lock
.claude/logs/*.lock
.claude/logs/*.lock.json
.claude/shared/*.lock
.superpowers/
.worktrees/
FitMe-GDPR-Docs/

# Local Xcode package resolution
FitTracker.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
node_modules/

# Python
__pycache__/
*.pyc
*.pyo
dashboard/node_modules/
dashboard/dist/
dashboard/.vercel/

# SSD-local build artifacts (caches, DerivedData, venvs, npm cache; .build/ also covered above)
orchid/.venv/

# Firebase credentials (local only, contains secrets)
GoogleService-Info.plist

# Local Xcode runtime overlays (real staging/debug credentials stay out of git)
Config/Local/*.xcconfig
!Config/Local/*.example.xcconfig
!Config/Local/README.md

# Auth-polish-v2 / Sentry / HADF / Vercel local artifacts (never commit)
.env.local
# Operator credential backups (.env.local.save, .env.local.backup, etc.) —
# always contain secrets; never commit. Added 2026-06-03 after HADF impl
# worktree surfaced an unstaged .env.local.save during the cleanup sweep.
# `.env.local.template` (committed operator runbook for the HADF env layout)
# is explicitly re-included via the !negation below.
.env.local.*
!.env.local.template
.sentryclirc
.venv-hadf-phase2/
.vercel/
.claude/shared/hadf/logs/
.claude/shared/hadf/pre-merge-backup-*/
.claude/shared/hadf/incident-*-recovery/
.claude/shared/hadf/*.pre-isolation-archive
.claude/shared/sentry-recovery/

# HADF Phase 2 raw observational data — gitignored per pre-registration
# (the committed summary derives from this; raw stays local to preserve the
# pre-registered "verdict is a pure function of (prereg, summary)" contract).
# NOTE: only the raw .jsonl files are excluded — the summary + preregistration
# JSON files ARE committed to satisfy the case study's T1 traceability claim
# (docs/case-studies/hadf-phase2-cloud-fingerprinting-case-study.md cites
# both files at commit 61964d3 as "the assessable inputs").
.claude/shared/hadf/phase2-fingerprint-raw*.jsonl
# HADF Phase 2-bis wrapper preflight test logs — transient outputs only,
# not deliverables. Real-run heartbeats go to phase2bis-fire-heartbeat.jsonl
# (which IS committed for path stability).
.claude/shared/hadf/phase2bis-deploy-verification/
.cache/
.claude/_session-state/

# Audit bundles — commit per-run artifacts for public reproducibility
# (decided 2026-05-19, spec §12 OQ #1). Each run directory commits
# bundle.md, manifest.json, redaction-log.json, plus the auditor's report.
# Only ad-hoc scratch / cache files under runs/*/ stay gitignored.
docs/audits/runs/*/scratch/
docs/audits/runs/*/.cache/
docs/audits/runs/*/*.tmp

# R9 (dev-env-master-plan-2026-05-24) — coverage artifacts.
# iOS Slather writes to .build/coverage-* (already ignored via .build/).
# ai-engine pytest-cov writes to .coverage + coverage.xml + htmlcov/.
ai-engine/.coverage
ai-engine/coverage.xml
ai-engine/htmlcov/

# F18 mutation testing (v8.0) — mutmut sqlite cache + root coverage + local
# partial summary. The authoritative mutation-score baseline is produced by the
# weekly mutation-test.yml CI run (uploaded as an artifact), not committed locally.
.mutmut-cache
/.coverage
.claude/shared/mutation-baseline.json

# FIT-181: machine-specific pre-commit latency report (regenerate via make profile-hooks)
.claude/shared/precommit-hook-latency.json
