# Copy this file to .env before running locally
# cp .env.example .env

# Supabase project URL (e.g. https://xyzxyz.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key — grants SECURITY DEFINER RPC access
# Never expose this publicly; AI engine only, server-side
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase JWKS endpoint for JWT validation
# Usually: https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Expected JWT audience (usually "authenticated" for Supabase)
SUPABASE_JWT_AUDIENCE=authenticated

# Optional: LLM API key for future advanced insight generation
# Leave commented out until LLM sub-processor DPA is in place
# LLM_API_KEY=your-llm-key

# Rate limiting (requests per segment per hour per user)
RATE_LIMIT_PER_HOUR=10

# k-anonymity floor — minimum frequency for a cohort bucket to be returned
K_ANONYMITY_FLOOR=50
