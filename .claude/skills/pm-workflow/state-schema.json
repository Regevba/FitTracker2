{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feature Lifecycle State",
  "description": "Tracks a feature through the PM lifecycle. Created by /pm-workflow, updated at each phase gate.",
  "type": "object",
  "required": ["feature", "created", "updated", "branch", "current_phase", "has_ui", "phases"],
  "properties": {
    "feature": { "type": "string", "description": "Feature slug (kebab-case)" },
    "created": { "type": "string", "format": "date-time" },
    "updated": { "type": "string", "format": "date-time" },
    "branch": { "type": "string", "description": "Git branch name" },
    "current_phase": {
      "type": "string",
      "enum": ["research", "prd", "tasks", "ux", "integration", "implement", "testing", "review", "merge", "docs", "complete"]
    },
    "has_ui": { "type": ["boolean", "null"] },
    "github_issue_number": { "type": ["integer", "null"], "description": "GitHub Issue number linked to this feature for dashboard sync" },
    "transitions": {
      "type": "array",
      "description": "Audit trail of all phase transitions (automatic + manual)",
      "items": {
        "type": "object",
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "approved_by": { "type": "string", "enum": ["user", "user-manual", "dashboard-drag"] },
          "note": { "type": "string" }
        },
        "required": ["from", "to", "timestamp", "approved_by"]
      }
    },
    "phases": {
      "type": "object",
      "properties": {
        "research": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "approved", "skipped"] },
            "approved_at": { "type": ["string", "null"], "format": "date-time" },
            "sources": { "type": "array", "items": { "type": "string" } }
          }
        },
        "prd": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "approved", "skipped"] },
            "approved_at": { "type": ["string", "null"], "format": "date-time" }
          }
        },
        "tasks": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "approved", "skipped"] },
            "count": { "type": "integer" }
          }
        },
        "ux_or_integration": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "approved", "skipped"] },
            "type": { "type": ["string", "null"], "enum": ["ux", "integration", null] },
            "compliance_passed": { "type": ["boolean", "null"] },
            "compliance_violations": { "type": "array", "items": { "type": "string" } },
            "compliance_decision": {
              "type": ["string", "null"],
              "enum": ["fix", "evolve", "override", null],
              "description": "User's decision when design system violations found: fix (comply), evolve (update design system), override (proceed with justification)"
            },
            "design_system_changes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "New tokens or components proposed for the design system by this feature"
            }
          }
        },
        "implementation": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "approved", "skipped"] },
            "commits": { "type": "array", "items": { "type": "string" } }
          }
        },
        "testing": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "approved", "skipped"] },
            "ci_passed": { "type": "boolean" },
            "tests_added": { "type": "integer" },
            "instrumentation_verified": { "type": "boolean" }
          }
        },
        "review": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "approved", "skipped"] },
            "risks": { "type": "array", "items": { "type": "string" } },
            "ci_main": { "type": "boolean" },
            "ci_feature": { "type": "boolean" }
          }
        },
        "merge": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "done", "skipped"] },
            "pr_number": { "type": ["integer", "null"] }
          }
        },
        "documentation": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["pending", "in_progress", "done", "skipped"] }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "baseline": { "type": ["number", "null"] },
                "target": { "type": ["number", "null"] },
                "current": { "type": ["number", "null"] }
              }
            },
            "secondary": { "type": "array", "items": { "type": "object" } },
            "guardrails": { "type": "array", "items": { "type": "object" } },
            "instrumentation_ready": { "type": "boolean" },
            "first_review_date": { "type": ["string", "null"], "format": "date" },
            "kill_criteria": { "type": "string" }
          }
        }
      }
    }
  }
}
