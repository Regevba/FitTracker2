{
  "$schema": "mapping-v1",
  "description": "Maps security audit MCP response fields to shared layer fields. Source paths use dot notation into the schema.json data payload. All values are real CVE scan results — never estimates.",
  "service": "security-audit",
  "version": "1.0",
  "target_shared_files": [
    "/Volumes/DevSSD/FitTracker2/.claude/shared/health-status.json",
    "/Volumes/DevSSD/FitTracker2/.claude/shared/test-coverage.json"
  ],
  "field_mappings": [
    {
      "source_path": "data.severityCounts",
      "target_file": "health-status.json",
      "target_path": "security.vulnerabilityCountsBySeverity",
      "match_on": null,
      "transform": "direct",
      "transform_note": "Replace the severity counts object. Keys: critical, high, medium, low. Any critical or high value > 0 should trigger an alert regardless of validation score.",
      "data_type": "measured",
      "overwrites_estimated": true
    },
    {
      "source_path": "data.totalVulnerabilities",
      "target_file": "health-status.json",
      "target_path": "security.totalVulnerabilities",
      "match_on": null,
      "transform": "direct",
      "transform_note": "Total CVE/advisory count across all scanned dependencies",
      "data_type": "measured",
      "overwrites_estimated": true
    },
    {
      "source_path": "data.fixAvailableCount",
      "target_file": "health-status.json",
      "target_path": "security.fixAvailableCount",
      "match_on": null,
      "transform": "direct",
      "transform_note": "Number of vulnerabilities with a patched version available — prioritized for immediate action",
      "data_type": "measured",
      "overwrites_estimated": true
    },
    {
      "source_path": "data.vulnerabilities",
      "target_file": "health-status.json",
      "target_path": "security.openVulnerabilities",
      "match_on": null,
      "transform": "custom",
      "transform_note": "Store only critical and high severity vulnerabilities here (filter by severity). Full list goes to test-coverage.json.",
      "data_type": "measured",
      "overwrites_estimated": true
    },
    {
      "source_path": "data.totalVulnerabilities",
      "target_file": "test-coverage.json",
      "target_path": "security.latestScan.vulnerabilityCount",
      "match_on": null,
      "transform": "direct",
      "transform_note": "Total vulnerabilities from the most recent scan",
      "data_type": "measured",
      "overwrites_estimated": true
    },
    {
      "source_path": "data.totalDependenciesScanned",
      "target_file": "test-coverage.json",
      "target_path": "security.latestScan.dependenciesScanned",
      "match_on": null,
      "transform": "direct",
      "transform_note": "Total dependency count audited in this scan",
      "data_type": "measured",
      "overwrites_estimated": true
    },
    {
      "source_path": "data.cleanDependencies",
      "target_file": "test-coverage.json",
      "target_path": "security.latestScan.cleanDependencies",
      "match_on": null,
      "transform": "direct",
      "transform_note": "Dependencies with no known vulnerabilities",
      "data_type": "measured",
      "overwrites_estimated": true
    },
    {
      "source_path": "data.vulnerabilities",
      "target_file": "test-coverage.json",
      "target_path": "security.latestScan.allVulnerabilities",
      "match_on": null,
      "transform": "direct",
      "transform_note": "Full vulnerability list including all severities. Stored for /qa and /dev detailed remediation tracking.",
      "data_type": "measured",
      "overwrites_estimated": true
    },
    {
      "source_path": "data.fixAvailableCount",
      "target_file": "test-coverage.json",
      "target_path": "security.latestScan.fixAvailableCount",
      "match_on": null,
      "transform": "direct",
      "transform_note": "Count of vulnerabilities that have a fix available",
      "data_type": "measured",
      "overwrites_estimated": true
    }
  ],
  "validation_rules": {
    "numeric_tolerance": 0.05,
    "description": "Numeric fields are considered consistent if within 5% of the existing shared layer value. Categorical fields (severity, cveId) must match exactly. New fields (null → value) are always consistent. Measured data superseding estimated data is always consistent. Note: a new critical vulnerability appearing (0 → 1+) is always consistent and must never be suppressed by the validation gate."
  }
}
