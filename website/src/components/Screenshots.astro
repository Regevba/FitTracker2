---
const screens = [
  { label: 'Dashboard', color: 'from-brand-primary to-brand-warm', items: ['Daily Summary', 'Activity Ring', 'Quick Actions'] },
  { label: 'Workout Log', color: 'from-blue-500 to-brand-secondary', items: ['Exercise Library', 'Set Tracking', 'Rest Timer'] },
  { label: 'Nutrition', color: 'from-green-500 to-emerald-400', items: ['Macro Breakdown', 'Meal History', 'Barcode Scanner'] },
  { label: 'Analytics', color: 'from-purple-500 to-pink-400', items: ['Strength Charts', 'Body Composition', 'Personal Records'] },
];
---
<section class="py-20 sm:py-28 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-text-primary mb-4">
        Designed for
        <span class="bg-gradient-to-r from-brand-secondary to-brand-primary bg-clip-text text-transparent">Every Detail</span>
      </h2>
      <p class="text-lg text-text-secondary max-w-2xl mx-auto">
        A clean, intuitive interface that makes tracking your fitness a joy, not a chore.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {screens.map((screen) => (
        <div class="group">
          <div class="relative bg-surface-dark-primary rounded-[2rem] p-1.5 shadow-xl group-hover:shadow-2xl transition-all group-hover:-translate-y-2">
            <div class={`bg-gradient-to-br ${screen.color} rounded-[1.75rem] aspect-[9/16] flex flex-col p-5`}>
              <div class="flex items-center justify-between mb-6">
                <div class="text-white/60 text-xs">9:41</div>
                <div class="flex gap-1">
                  <div class="w-3.5 h-3.5 bg-white/20 rounded-full"></div>
                  <div class="w-3.5 h-3.5 bg-white/20 rounded-full"></div>
                </div>
              </div>
              <div class="text-white text-lg font-bold mb-1">{screen.label}</div>
              <div class="text-white/60 text-xs mb-4">FitMe</div>
              <div class="flex-1 space-y-2.5">
                {screen.items.map((item) => (
                  <div class="bg-white/15 backdrop-blur-sm rounded-xl p-3">
                    <div class="text-white text-sm font-medium">{item}</div>
                    <div class="mt-2 h-1.5 bg-white/20 rounded-full">
                      <div class="h-full bg-white/50 rounded-full" style={`width: ${50 + Math.random() * 40}%`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div class="text-center mt-4">
            <div class="text-sm font-semibold text-text-primary">{screen.label}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
