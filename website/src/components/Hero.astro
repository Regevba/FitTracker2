---
---
<section id="hero" class="relative pt-28 pb-20 sm:pt-36 sm:pb-28 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-cool/50 via-white to-brand-warm/20 -z-10"></div>
  <div class="absolute top-20 right-0 w-96 h-96 bg-brand-primary/10 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 w-72 h-72 bg-brand-secondary/10 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 bg-brand-primary/10 text-brand-primary text-sm font-medium px-4 py-1.5 rounded-full mb-6">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          Your Fitness Command Center
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-text-primary leading-tight mb-6">
          Train Smarter.
          <span class="bg-gradient-to-r from-brand-primary to-brand-warm bg-clip-text text-transparent">
            Live Stronger.
          </span>
        </h1>

        <p class="text-lg sm:text-xl text-text-secondary max-w-lg mx-auto lg:mx-0 mb-8 leading-relaxed">
          Track workouts, nutrition, and recovery in one beautiful app. AI-powered insights help you reach your goals faster.
        </p>

        <div id="download" class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
          <a
            href="https://apps.apple.com/app/fitme"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 bg-black hover:bg-gray-800 text-white px-6 py-3.5 rounded-xl transition-all hover:shadow-xl hover:-translate-y-0.5"
            data-cta="hero"
            data-cta-type="app_store"
          >
            <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <div class="text-left">
              <div class="text-[10px] uppercase tracking-wider opacity-80">Download on the</div>
              <div class="text-base font-semibold -mt-0.5">App Store</div>
            </div>
          </a>

          <a href="#features" class="inline-flex items-center gap-2 text-brand-primary font-semibold hover:underline" data-cta="hero" data-cta-type="learn_more">
            See what's inside
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </a>
        </div>
      </div>

      <div class="relative flex justify-center lg:justify-end">
        <div class="relative w-64 sm:w-72">
          <div class="absolute inset-0 bg-gradient-to-br from-brand-primary/20 to-brand-secondary/20 rounded-[3rem] blur-2xl scale-105"></div>
          <div class="relative bg-surface-dark-primary rounded-[2.5rem] p-2 shadow-2xl">
            <div class="bg-gradient-to-br from-brand-primary via-brand-warm to-brand-secondary rounded-[2rem] aspect-[9/19.5] flex flex-col items-center justify-center text-white p-6">
              <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center mb-4 backdrop-blur-sm">
                <span class="text-3xl font-bold">F</span>
              </div>
              <div class="text-2xl font-bold mb-1">FitMe</div>
              <div class="text-sm opacity-80 mb-8">Your Fitness Command Center</div>
              <div class="w-full space-y-3">
                <div class="bg-white/15 backdrop-blur-sm rounded-xl p-3 flex items-center gap-3">
                  <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center text-xs">🏋️</div>
                  <div class="text-sm">Today's Workout</div>
                </div>
                <div class="bg-white/15 backdrop-blur-sm rounded-xl p-3 flex items-center gap-3">
                  <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center text-xs">🥗</div>
                  <div class="text-sm">Nutrition Log</div>
                </div>
                <div class="bg-white/15 backdrop-blur-sm rounded-xl p-3 flex items-center gap-3">
                  <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center text-xs">📊</div>
                  <div class="text-sm">Progress Stats</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
