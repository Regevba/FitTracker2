---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import Dashboard from '../components/Dashboard.jsx';
import { buildDashboardData } from '../scripts/builders/controlCenter.js';

const dashboardData = await buildDashboardData({ token: import.meta.env.GITHUB_TOKEN });
---

<DashboardLayout>
  <Dashboard
    {...dashboardData}
    lastSync={dashboardData.externalSyncStatus.updated}
    client:load
  />
</DashboardLayout>
