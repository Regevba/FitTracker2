---
import '../styles/global.css';
import SpeedInsights from '@vercel/speed-insights/astro';
const { title = 'FitMe — Operations Control Room' } = Astro.props;
// PUBLIC_GA_ID enables TTC baseline capture for the unified-control-center
// migration (feature task T1). Set in Vercel project env vars; reuse the
// same GA property the fitme-story showcase uses.
const GA_ID = import.meta.env.PUBLIC_GA_ID;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="FitMe operations control room — inspect delivery, system health, UX quality, product intelligence, and source-of-truth drift across the project." />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💪</text></svg>" />
  {GA_ID && (
    <>
      {/* GA4 loaded async per `bundle-defer-third-party` + `rendering-script-defer-async` */}
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
      <script is:inline define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', GA_ID, { send_page_view: true });
        // TTC anchor — capture page-load time as early as possible (before React hydrates).
        window.__dashboardLoadAt = Date.now();
      </script>
    </>
  )}
  <style>
    /* Kanban horizontal scroll on tablet */
    @media (max-width: 1024px) {
      .kanban-scroll { scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
      .kanban-scroll > div { scroll-snap-align: start; min-width: 260px; }
    }
    /* Mobile: stack kanban columns vertically */
    @media (max-width: 640px) {
      .kanban-scroll { flex-direction: column !important; overflow-x: visible !important; }
      .kanban-scroll > div { width: 100% !important; min-width: unset !important; }
    }
    /* Touch-friendly tap targets */
    @media (pointer: coarse) {
      button, a, [role="button"] { min-height: 44px; min-width: 44px; }
    }
  </style>
</head>
<body class="min-h-screen bg-[linear-gradient(180deg,#f7efe7_0%,#f6f7fb_35%,#eef4fb_100%)] text-slate-950 transition-colors duration-200 dark:bg-[linear-gradient(180deg,#06080d_0%,#0b0d12_38%,#11141c_100%)] dark:text-white">
  <slot />
  <SpeedInsights />
</body>
</html>
