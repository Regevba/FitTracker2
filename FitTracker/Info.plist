<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UILaunchScreen</key>
	<dict/>
	<key>AIEngineBaseURL</key>
	<string>$(FITTRACKER_AI_ENGINE_BASE_URL)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>FitMe</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>GoogleSignIn</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(FITTRACKER_GOOGLE_REVERSED_CLIENT_ID)</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>PasswordReset</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>fitme</string>
			</array>
		</dict>
	</array>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>FirebaseAutomaticScreenReportingEnabled</key>
	<false/>
	<key>FitTrackerEnvironmentName</key>
	<string>$(FITTRACKER_APP_ENVIRONMENT)</string>
	<key>FitTrackerRuntimeConfigSource</key>
	<string>$(FITTRACKER_RUNTIME_CONFIG_SOURCE)</string>
	<key>GoogleClientID</key>
	<string>$(FITTRACKER_GOOGLE_CLIENT_ID)</string>
	<key>GoogleReversedClientID</key>
	<string>$(FITTRACKER_GOOGLE_REVERSED_CLIENT_ID)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.healthcare-fitness</string>
	<key>NSFaceIDUsageDescription</key>
	<string>FitMe uses Face ID to unlock your encrypted health data and confirm sensitive account actions.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>FitMe reads Health data so your recovery, activity, and biometric metrics stay up to date.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>FitMe writes workout and energy data back to Health when you choose to sync your training activity.</string>
	<key>NSUserTrackingUsageDescription</key>
	<string>FitMe uses this to understand how the app is used and improve your experience. No health data is shared.</string>
	<key>PasskeyRelyingPartyID</key>
	<string>$(FITTRACKER_PASSKEY_RELYING_PARTY_ID)</string>
	<key>SupabaseAnonKey</key>
	<string>$(FITTRACKER_SUPABASE_ANON_KEY)</string>
	<key>SupabaseURL</key>
	<string>$(FITTRACKER_SUPABASE_URL)</string>
</dict>
</plist>
