<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>FitTracker</string>
	<key>CFBundleIdentifier</key>
	<string>com.fittracker.regev</string>
	<key>CFBundleVersion</key>
	<string>2</string>
	<key>CFBundleShortVersionString</key>
	<string>2.0</string>

	<!-- Minimum iOS version: 17.0 (enforces Apple silicon / modern iPhone/iPad) -->
	<key>MinimumOSVersion</key>
	<string>17.0</string>

	<!-- HealthKit privacy descriptions (required by App Store review) -->
	<key>NSHealthShareUsageDescription</key>
	<string>FitTracker reads heart rate, HRV, weight, body fat, sleep, steps and VO2max from Apple Health to track your recovery progress and training readiness. All data stays on your device and is double-encrypted before any cloud sync.</string>

	<key>NSHealthUpdateUsageDescription</key>
	<string>FitTracker writes completed workouts back to Apple Health to keep your fitness history in one place.</string>

	<!-- Face ID / Touch ID -->
	<key>NSFaceIDUsageDescription</key>
	<string>FitTracker uses Face ID to protect access to your encrypted health data. No data can be accessed without biometric or passcode authentication.</string>

	<!-- Camera (for cardio session photo capture) -->
	<key>NSCameraUsageDescription</key>
	<string>FitTracker uses the camera to photograph the elliptical or rowing machine's summary screen, capturing your complete session data automatically.</string>

	<!-- Photo library (for selecting existing photos) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>FitTracker can save or access cardio session summary photos from your photo library.</string>

	<!-- Microphone (not used — deny access) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>FitTracker does not use the microphone.</string>

	<!-- Background modes -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
		<string>remote-notification</string>
	</array>

	<!-- Supported orientations: iPhone -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>

	<!-- Supported orientations: iPad (all) -->
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Sign in with Apple (no extra config needed — handled by AuthenticationServices) -->

	<!-- Google Sign-In: replace YOUR_REVERSED_CLIENT_ID with value from GoogleService-Info.plist -->
	<!-- e.g. com.googleusercontent.apps.123456789-abcdefgh -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>YOUR_REVERSED_CLIENT_ID</string>
			</array>
		</dict>
	</array>
	<!-- Google Sign-In client ID (from GoogleService-Info.plist) -->
	<key>GIDClientID</key>
	<string>YOUR_CLIENT_ID.apps.googleusercontent.com</string>

	<!-- Facebook Sign-In: replace FACEBOOK_APP_ID and FACEBOOK_CLIENT_TOKEN -->
	<key>FacebookAppID</key>
	<string>YOUR_FACEBOOK_APP_ID</string>
	<key>FacebookClientToken</key>
	<string>YOUR_FACEBOOK_CLIENT_TOKEN</string>
	<key>FacebookDisplayName</key>
	<string>FitTracker</string>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>fbapi</string>
		<string>fb-messenger-share-api</string>
	</array>

	<!-- Passkey relying party domain (must match your associated domain) -->
	<!-- Add Associated Domains capability: webcredentials:fittracker.regev.app -->
	<key>PasskeyRelyingPartyID</key>
	<string>fittracker.regev.app</string>

	<!-- Launch screen (SwiftUI managed) -->
	<key>UILaunchScreen</key>
	<dict/>

	<!-- iCloud containers -->
	<key>NSUbiquitousContainers</key>
	<dict>
		<key>iCloud.com.fittracker.regev</key>
		<dict>
			<key>NSUbiquitousContainerIsDocumentScopePublic</key>
			<false/>
			<key>NSUbiquitousContainerName</key>
			<string>FitTracker</string>
			<key>NSUbiquitousContainerSupportedFolderLevels</key>
			<string>None</string>
		</dict>
	</dict>

	<!-- Requires Apple environment — enforced by App Store / Mac App Store distribution -->
	<!-- Additional runtime check in FitTrackerApp.swift -->
</dict>
</plist>
