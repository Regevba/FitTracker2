#!/usr/bin/env bash
# Git pre-commit hook — gates the v7.5/v7.6 Data Integrity Framework's
# write-time defenses. Blocks commits that would introduce:
#
#   v7.5 (shipped 2026-04-21):
#     - SCHEMA_DRIFT (legacy `phase` key on state.json)
#     - PR_NUMBER_UNRESOLVED (state.json.phases.merge.pr_number doesn't resolve)
#
#   v7.6 (shipped 2026-04-25, Phase 1 Class B → A closure):
#     - PHASE_TRANSITION_NO_LOG (current_phase changed without a fresh
#       phase_started/phase_approved/etc. event in .claude/logs/<feature>.log.json)
#     - PHASE_TRANSITION_NO_TIMING (current_phase changed without
#       timing.phases.<old>.ended_at + timing.phases.<new>.started_at)
#     - BROKEN_PR_CITATION (case study cites a PR that doesn't resolve)
#     - CASE_STUDY_MISSING_TIER_TAGS (post-2026-04-21 case study without
#       T1/T2/T3 tier tags)
#
# Enable with: make install-hooks
# Bypass (emergency only): git commit --no-verify
#   (The 72h integrity cycle still catches anything introduced via bypass.)

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
state_schema_checker="$repo_root/scripts/check-state-schema.py"
case_study_checker="$repo_root/scripts/check-case-study-preflight.py"

failed=0

# Defense layer 1: state.json schema + transition gates.
if [[ -x "$state_schema_checker" ]]; then
  if ! "$state_schema_checker" --staged; then
    failed=1
  fi
fi

# Defense layer 2: case-study preflight (PR citations + tier tags).
if [[ -x "$case_study_checker" ]]; then
  if ! "$case_study_checker" --staged; then
    failed=1
  fi
fi

if [[ "$failed" -ne 0 ]]; then
  echo ""
  echo "Pre-commit rejected: one or more v7.5/v7.6 framework gates failed."
  echo "Address each violation listed above, restage, and recommit."
  echo "Emergency bypass: git commit --no-verify (the 72h cycle will still flag the issue)."
  exit 1
fi
